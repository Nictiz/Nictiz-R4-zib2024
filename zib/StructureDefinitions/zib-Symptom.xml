      <path value="Observation.effective[x]" />
      <slicing>
        <discriminator>
          <type value="type" />
          <path value="$this" />
        </discriminator>
        <rules value="open" />
      </slicing>
    </element>
    <element id="Observation.effective[x]:effectiveDateTime">
      <path value="Observation.effective[x]" />
      <sliceName value="effectiveDateTime" />
      <short value="SymptomStatusDate" />
      <definition value="Date from which the specification of the symptom applies." />
      <alias value="SymptoomStatusDatum" />
      <type>
        <code value="dateTime" />
      </type>
      <mapping>
        <identity value="zib-symptom-v1.0-2024EN" />
        <map value="NL-CM:5.5.3" />
        <comment value="SymptomStatusDate" />
      </mapping>
    </element>
